        </style><div class="panel-group--r-3d- relative grid h-full w-full max-w-full contain-strict px-2 sm:pb-2" style="transition-property: grid-template-columns; transition-duration: 0ms; transition-timing-function: cubic-bezier(0.31, 0.1, 0.08, 0.96); transition-delay: 0ms; will-change: grid-template-columns;"><div class="relative overflow-hidden" style="grid-area: input; opacity: 0; pointer-events: none; transition-property: opacity; transition-duration: 0ms; transition-timing-function: cubic-bezier(0.31, 0.1, 0.08, 0.96); transition-delay: 0ms; will-change: auto;"><div class="absolute inset-[2px] rounded-xl bg-v0-gray-100"></div></div><div class="z-10 flex h-full w-full flex-col overflow-hidden rounded-xl relative" style="grid-area: input; opacity: 1; transition-property: opacity, transform; transition-duration: 0ms; transition-timing-function: cubic-bezier(0.31, 0.1, 0.08, 0.96); transition-delay: 0ms; will-change: auto; content-visibility: visible;"><div class="relative flex h-full min-w-0 flex-1 sm:pr-2" data-testid="full-chat"><div class="relative flex min-w-0 flex-1"><div class="flex flex-col size-full relative"><script>
  requestAnimationFrame(() => {
    globalThis.__VERCEL_NAVIGATION_METRICS_RECORDED_MEASURES = globalThis.__VERCEL_NAVIGATION_METRICS_RECORDED_MEASURES || new Map();
    if (globalThis.__VERCEL_NAVIGATION_METRICS_RECORDED_MEASURES.has("content visible")) {
      
      return;
    }
    globalThis.__VERCEL_NAVIGATION_METRICS_RECORDED_MEASURES.set("content visible", "ChatMessagesWithPrompt");

    try {
      performance.measure("content visible", {
        end: performance.now(),
        detail: {
          vercelNavigation: {
            isHardNavigation: true,
            attrs: JSON.parse("{\"phase\":\"content\",\"label\":\"ChatMessagesWithPrompt\",\"route\":\"/chat/[slug]\",\"target_env\":\"production\",\"state\":\"visible\"}"),
          },
