          (function() {
            const textarea = document.getElementById("prompt-textarea-_new-chat_");
            if (!textarea) return;

            function applyValue(value) {
              if (!value) return;
              textarea.value = value;
              textarea.style.height = 'auto';
              textarea.style.height = Math.min(textarea.scrollHeight, 330) + 'px';
            }

            try {
              // 1. URL ?q= param (only on new-chat pages; existing chats ignore it).
              if (true) {
                const q = new URLSearchParams(window.location.search).get('q');
                if (q) {
                  applyValue(q);
                  return;
                }
              }

              // 2. localStorage draft fallback.
              const draftsJson = localStorage.getItem('v0-local-drafts');
              if (!draftsJson) return;

              const drafts = JSON.parse(draftsJson);
              const draft = drafts["_new-chat_"];
              if (!draft) return;

              if (draft.text) {
                applyValue(draft.text);
              } else if (draft.html) {
                // WARNING: extractTextFromHtml is serialized via Function.prototype.toString()
